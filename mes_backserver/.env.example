# 이 파일을 복사해서 .env 로 만들고 값을 채우세요 (.env 는 git에 올리지 않음)
# cp .env.example .env

OPENAI_API_KEY=
MES_DB_PASSWORD=
JWT_SECRET=
OPENAI_MODEL=gpt-5-mini

# 운영 배포 시 Vercel 프론트 주소로 변경
SECURITY_ALLOWED_ORIGINS=http://localhost:3000

# 데모 시뮬레이터 — 운영에서는 false
PLC_SIM_ENABLED=false

# 이메일 알림 (안 쓰면 비워두기)
NOTIFICATION_EMAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=
