# Copy this file to .env and fill values.
# Do not commit the real .env file.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.0

MES_DB_PASSWORD=
JWT_SECRET=

SECURITY_ALLOWED_ORIGINS=http://localhost:3000

# Demo simulator. Keep false in production except during a temporary smoke test.
PLC_SIM_ENABLED=false

# Email notifications.
NOTIFICATION_EMAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=
