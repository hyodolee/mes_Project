<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mcs.infra.persistence.mybatis.mapper.mes.MesWarehouseMapper">
    <select id="selectWarehouseList" resultType="com.mcs.domain.mes.dto.WarehouseDto">
        SELECT
            WAREHOUSE_CD,
            PLANT_CD,
            WAREHOUSE_NM,
            WAREHOUSE_TYPE,
            USE_YN
        FROM MST_WAREHOUSE
        <where>
            <if test="plantCd != null and plantCd != ''">AND PLANT_CD = #{plantCd}</if>
            <if test="warehouseCd != null and warehouseCd != ''">AND WAREHOUSE_CD = #{warehouseCd}</if>
            <if test="useYn != null and useYn != ''">AND USE_YN = #{useYn}</if>
        </where>
        ORDER BY WAREHOUSE_CD
    </select>
</mapper>
